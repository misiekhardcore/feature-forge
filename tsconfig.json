{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "src/**/*.ts",
    "e2e/**/*.ts",
    "scripts/**/*.ts",
    "vitest.config.ts",
    "vitest.e2e.config.ts",
    "eslint.config.js"
  ],
  "exclude": ["node_modules", "dist"]
}
