{
  "name": "feature-forge",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous software engineering platform — idea to PR via structured discovery, ADR-driven design, and multi-agent implementation",
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src/**/*.ts",
    "agents/**/*",
    "skills/**/*",
    "prompts/**/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "changelog": "git-cliff -o CHANGELOG.md",
    "check": "npm run lint && npm run format && npm run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.79.8"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.79.10",
    "@earendil-works/pi-ai": "0.79.10",
    "@earendil-works/pi-tui": "^0.79.8",
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "10.5.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "typebox": "1.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
