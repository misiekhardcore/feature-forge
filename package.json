{
  "name": "feature-forge",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous software engineering platform — idea to PR via structured discovery, ADR-driven design, and multi-agent implementation",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@11.11.0",
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "flow:generate-schema": "npm -w @feature-forge/cli run flow:generate-schema",
    "flow:validate": "npm -w @feature-forge/cli run flow:validate",
    "flow:validate-json": "npm -w @feature-forge/cli run flow:validate-json",
    "check": "npm run lint && npm run format && npm run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "turbo": "^2.5.3",
    "typebox": "1.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
