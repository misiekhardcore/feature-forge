{
  "name": "feature-forge",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous software engineering platform — idea to PR via structured discovery, ADR-driven design, and multi-agent implementation",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@11.11.0",
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:fix": "turbo run format:fix",
    "typecheck": "turbo run typecheck",
    "flow:generate-schema": "npm -w @feature-forge/cli run flow:generate-schema",
    "flow:validate": "npm -w @feature-forge/cli run flow:validate",
    "flow:validate-json": "npm -w @feature-forge/cli run flow:validate-json",
    "check": "npm run lint && npm run format && npm run test",
    "fix": "npm run lint:fix && npm run format:fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,md,yml,yaml}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "pi": {
    "extensions": [
      "./packages/cli/src/index.ts"
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "turbo": "^2.5.3",
    "typebox": "1.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
