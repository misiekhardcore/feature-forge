{
  "name": "implement",
  "command": "/implement",
  "orchestrator": {
    "prompt": "orchestrator.md",
    "activeTools": ["run_build_loop", "open_pr", "destroy_workspace"]
  },
  "routines": {
    "run_build_loop": {
      "params": [
        { "name": "task", "description": "The task description" },
        { "name": "plan", "description": "The implementation plan" }
      ],
      "steps": [
        {
          "type": "workspace",
          "id": "workspace"
        },
        {
          "type": "loop",
          "id": "build_loop",
          "maxIterations": 5,
          "continueWhile": "!results.builder?.parsed?.passed || !results.review?.parsed?.passed || !results.verify?.parsed?.passed",
          "accumulateFrom": ["review", "verify"],
          "steps": [
            {
              "type": "agent",
              "id": "builder",
              "spec": "build",
              "workingDir": "workspace",
              "parseJson": true,
              "specInput": {
                "CONTEXT": "{{task}}\n\nPlan:\n{{plan}}",
                "TASK": "{{task}}",
                "FEEDBACK": "{{feedback}}",
                "WORKSPACE": "{{workspace}}"
              },
              "task": "Build per the plan. End your response with a JSON block reporting the build outcome:\n```json\n{\n  \"passed\": true|false,\n  \"summary\": \"Brief description of what was built or attempted\"\n}\n```\n\nOnly report passed: true if you created/modified files and all tests pass. If the build failed, report passed: false with a summary of the failure."
            },
            {
              "type": "parallel",
              "id": "inspect",
              "steps": [
                {
                  "type": "agent",
                  "id": "review",
                  "spec": "review",
                  "workingDir": "workspace",
                  "parseJson": true,
                  "specInput": {
                    "CONTEXT": "{{task}}",
                    "BUILD_OUTPUT": "{{results.builder.raw}}",
                    "ACCEPTANCE_CRITERIA": "{{task}}"
                  },
                  "task": "Review the code changes."
                },
                {
                  "type": "agent",
                  "id": "verify",
                  "spec": "verify",
                  "workingDir": "workspace",
                  "parseJson": true,
                  "specInput": {
                    "CONTEXT": "{{task}}",
                    "BUILD_OUTPUT": "{{results.builder.raw}}",
                    "ACCEPTANCE_CRITERIA": "{{task}}"
                  },
                  "task": "Verify acceptance criteria."
                }
              ]
            }
          ]
        }
      ]
    },
    "open_pr": {
      "params": [
        { "name": "workspace", "description": "Absolute path to the workspace worktree" },
        { "name": "task", "description": "PR title" }
      ],
      "steps": [
        {
          "type": "shell",
          "id": "commit",
          "command": "git add -A && git commit -m \"{{task}}\" --allow-empty"
        },
        {
          "type": "shell",
          "id": "push",
          "command": "git push origin HEAD"
        },
        {
          "type": "shell",
          "id": "pr",
          "command": "gh pr create --title \"{{task}}\" --body \"Automated PR from /implement flow\""
        }
      ]
    },
    "destroy_workspace": {
      "params": [
        { "name": "workspace", "description": "Absolute path to the workspace directory" }
      ],
      "steps": [
        {
          "type": "cleanup",
          "id": "destroy_workspace_cleanup"
        }
      ]
    }
  }
}
