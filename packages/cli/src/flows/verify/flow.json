{
  "$schema": "https://raw.githubusercontent.com/misiekhardcore/feature-forge/main/packages/cli/src/flows/flow-schema.json",
  "name": "verify",
  "command": "/verify",
  "orchestrator": {
    "systemPrompt": "verify-orchestrator"
  },
  "routines": [
    {
      "id": "check",
      "params": [
        {
          "name": "output",
          "description": "Raw output from previous step",
          "required": true
        },
        {
          "name": "workspace",
          "description": "Absolute path to the workspace"
        }
      ],
      "steps": [
        {
          "type": "agent",
          "id": "verify",
          "systemPrompt": "verify",
          "workingDir": {
            "path": "{{workspace}}"
          },
          "parseJson": true,
          "prompt": "Verify that every acceptance criterion and issue objective is met, and that e2e coverage is sufficient. Run e2e tests if available.\n\nTask:\n{{prompt}}\n\nPrevious step output:\n{{output}}"
        }
      ]
    }
  ]
}
