{
  "name": "@feature-forge/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Feature Forge CLI — autonomous software engineering platform",
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src/**/*.ts"
  ],
  "main": "./src/index.ts",
  "scripts": {
    "build": "echo 'cli: nothing to build'",
    "test": "echo 'cli: tests via vitest workspace'",
    "lint": "echo 'cli: linted via root'",
    "format": "echo 'cli: formatted via root'",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "test:e2e": "vitest run --project cli-e2e",
    "flow:generate-schema": "npx tsx scripts/generate-flow-schema.ts",
    "flow:validate": "npx tsx scripts/validate-flow.ts",
    "flow:validate-json": "npx tsx scripts/validate-flow-json.ts",
    "changelog": "git-cliff -o CHANGELOG.md"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.79.10",
    "@earendil-works/pi-ai": "0.79.10",
    "@earendil-works/pi-coding-agent": "0.79.8",
    "@earendil-works/pi-tui": "0.79.8",
    "@feature-forge/shared": "*"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typebox": "1.3.0"
  }
}
