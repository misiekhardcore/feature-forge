{
  "name": "@feature-forge/eslint-config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared ESLint configuration for feature-forge packages",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "build": "echo 'eslint-config: nothing to build'",
